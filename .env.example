# Local demo defaults for the controlled Gozar Core lab.
# Copy to .env before running docker compose locally:
#   cp .env.example .env
# These values are intentionally rejected unless GOZAR_ALLOW_INSECURE_DEV_DEFAULTS=true.

GOZAR_ALLOW_INSECURE_DEV_DEFAULTS=true

# Docker Compose interpolation values.
GOZAR_CONTROL_SECRET=gozar-local-shared-secret
GOZAR_ADMIN_TOKEN=gozar-admin-token

# Direct TypeScript control-plane execution values.
CONTROL_SECRET=gozar-local-shared-secret
ADMIN_TOKEN=gozar-admin-token
